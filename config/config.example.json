{
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "debug": true,
    "environment": "development"
  },
  "llm": {
    "default_provider": "ollama",
    "default_model": "llama3",
    "providers": {
      "ollama": {
        "base_url": "http://localhost:11434",
        "model": "llama3"
      },
      "huggingface": {
        "api_key": "your_huggingface_api_key_here",
        "model": "mistralai/Mistral-7B-Instruct-v0.2",
        "inference_provider": "hf",
        "router_base_url": "https://router.huggingface.co",
        "inference_base_url": "https://api-inference.huggingface.co",
        "text_to_image_model": "black-forest-labs/FLUX.1-schnell",
        "image_to_text_model": "Salesforce/blip-image-captioning-large",
        "speech_to_text_model": "openai/whisper-large-v3-turbo",
        "text_to_speech_model": "facebook/fastspeech2-en-ljspeech",
        "text_to_audio_model": "facebook/musicgen-small",
        "summarization_model": "facebook/bart-large-cnn",
        "embedding_model": "Qwen/Qwen3-Embedding-8B",
        "object_detection_model": "facebook/detr-resnet-50",
        "gradio_spaces": {
          "naive_rag": "https://bstraehle-rag.hf.space",
          "advanced_rag": "https://bstraehle-advanced-rag.hf.space",
          "agentic_crewai": "https://bstraehle-multi-agent-crewai.hf.space",
          "agentic_langgraph": "https://bstraehle-multi-agent-langgraph.hf.space",
          "agentic_openai": "https://bstraehle-agentic-rag-openai.hf.space"
        }
      },
      "gemini": {
        "api_key": "your_gemini_api_key_here",
        "model": "gemini-2.5-flash",
        "embedding_model": "gemini-embedding-001",
        "vision_model": "gemini-2.5-flash",
        "base_url": "https://generativelanguage.googleapis.com/v1beta",
        "imagen_model": "imagen-4.0-generate-001",
        "veo_model": "veo-3.0-fast-generate-001"
      },
      "ai21": {
        "api_key": "your_ai21_api_key_here",
        "model": "jamba-large-1.7",
        "base_url": "https://api.ai21.com/studio/v1"
      },
      "cerebras": {
        "api_key": "your_cerebras_api_key_here",
        "base_url": "https://api.cerebras.ai/v1",
        "model": "llama-3.3-70b"
      },
      "groq": {
        "api_key": "your_groq_api_key_here",
        "base_url": "https://api.groq.com/openai/v1",
        "model": "llama-3.3-70b-versatile",
        "vision_model": "llama-3.2-11b-vision-preview",
        "safety_model": "meta-llama/llama-guard-4-12b",
        "prompt_guard_model": "meta-llama/llama-prompt-guard-2-86m",
        "reasoning_model": "deepseek-r1-distill-llama-70b",
        "coding_model": "qwen-2.5-coder-32b",
        "enable_auto_model_selection": true
      },
      "nvidia": {
        "api_key": "your_nvidia_api_key_here",
        "base_url": "https://integrate.api.nvidia.com/v1",
        "genai_base_url": "https://ai.api.nvidia.com/v1",
        "nim_base_url": "https://ai.api.nvidia.com/v1",
        "model": "nvidia/llama-3.3-nemotron-super-49b-v1",
        "chat_model": "nvidia/llama-3.3-nemotron-super-49b-v1",
        "embedding_model": "nvidia/nv-embedqa-e5-v5",
        "vision_model": "meta/llama-3.2-90b-vision-instruct",
        "timeout": 120.0,
        "chat_timeout": 120.0,
        "embedding_timeout": 60.0,
        "vision_timeout": 180.0,
        "nim_timeout": 300.0
      },
      "openrouter": {
        "api_key": "your_openrouter_api_key_here",
        "base_url": "https://openrouter.ai/api/v1",
        "model": "openrouter/auto",
        "site_url": "https://your-site.com",
        "app_name": "DurgasAI",
        "enable_auto_routing": true,
        "fallback_models": [
          "openai/gpt-4o-mini",
          "anthropic/claude-3.5-haiku",
          "google/gemini-2.0-flash-001"
        ]
      },
      "fal": {
        "api_key": "your_fal_api_key_here",
        "base_url": "https://queue.fal.run/fal-ai",
        "default_timeout": 600.0,
        "polling_interval": 2.0,
        "max_polling_attempts": 150
      },
      "fireworks": {
        "api_key": "your_fireworks_api_key_here",
        "base_url": "https://api.fireworks.ai/inference/v1",
        "model": "accounts/fireworks/models/llama-v3-70b-instruct"
      },
      "deepinfra": {
        "api_key": "your_deepinfra_api_key_here",
        "base_url": "https://api.deepinfra.com/v1/openai",
        "inference_base_url": "https://api.deepinfra.com/v1",
        "model": "google/gemma-7b-it",
        "embedding_model": "thenlper/gte-large",
        "image_model": "black-forest-labs/FLUX-1-schnell"
      },
      "anyscale": {
        "api_key": "your_anyscale_api_key_here",
        "base_url": "https://api.endpoints.anyscale.com/v1",
        "model": "meta-llama/Llama-3-70b-chat-hf"
      },
      "cohere": {
        "api_key": "your_cohere_api_key_here",
        "base_url": "https://api.cohere.ai/v1",
        "model": "command-r-plus",
        "embed_model": "embed-english-v3.0",
        "rerank_model": "rerank-english-v3.0",
        "classify_model": "embed-english-v3.0"
      },
      "hyperbolic": {
        "api_key": "your_hyperbolic_api_key_here",
        "base_url": "https://api.hyperbolic.xyz/v1",
        "default_text_model": "meta-llama/Meta-Llama-3.1-70B-Instruct",
        "default_vision_model": "meta-llama/Llama-3.2-90B-Vision-Instruct",
        "default_image_model": "FLUX.1-dev",
        "timeout": 120.0
      },
      "reka": {
        "api_key": "your_reka_api_key_here",
        "base_url": "https://api.reka.ai/v1",
        "model": "reka-flash-3",
        "timeout": 120.0
      }
    }
  },
  "deepgram": {
    "api_key": "your_deepgram_api_key_here",
    "base_url": "https://api.deepgram.com/v1",
    "default_stt_model": "nova-2",
    "default_tts_model": "aura-asteria-en",
    "timeout": 120.0
  },
  "elevenlabs": {
    "api_key": "your_elevenlabs_api_key_here",
    "base_url": "https://api.elevenlabs.io/v1",
    "default_voice_id": "pMsXgVXv3BLzUgSXRplE",
    "default_model_id": "eleven_multilingual_v2",
    "timeout": 120.0,
    "cache_ttl": 3600
  },
  "embeddings": {
    "provider": "local",
    "model": "all-MiniLM-L6-v2"
  },
  "database": {
    "url": "sqlite+aiosqlite:///./data/durgasai.db",
    "chroma_persist_dir": "./data/chroma",
    "chroma_collection_name": "durgasai_pages"
  },
  "redis": {
    "url": "redis://localhost:6379",
    "use_redis": false
  },
  "security": {
    "jwt_secret_key": "your-super-secret-jwt-key-change-in-production",
    "jwt_algorithm": "HS256",
    "jwt_access_token_expire_minutes": 30,
    "api_key": "your-api-key-for-extension"
  },
  "rate_limiting": {
    "per_minute": 100,
    "burst": 20
  },
  "cors": {
    "origins": "chrome-extension://,http://localhost:3000,http://localhost:8080"
  },
  "supabase": {
    "url": "",
    "anon_key": "",
    "service_role_key": "",
    "jwt_secret": "",
    "db_url": "",
    "studio_url": "http://localhost:3001",
    "enable_realtime": true,
    "storage_buckets": {
      "uploads": "user-uploads",
      "avatars": "user-avatars",
      "documents": "rag-documents"
    }
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  },
  "council": {
    "min_models": 3,
    "max_models": 5,
    "enable_auto_selection": true,
    "timeout_seconds": 120,
    "preferred_chairman": "gemini"
  }
}
