# DurgasAI Backend Configuration
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# ===================
# AI Provider Settings
# ===================
# Default LLM provider: ollama, huggingface, gemini
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_MODEL=llama3

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Google Gemini Configuration (Optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# AI21 Labs Configuration (Optional)
AI21_API_KEY=your_ai21_api_key_here
AI21_MODEL=jamba-large-1.7

# Alibaba Cloud (Qwen) Configuration (Optional)
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALIBABA_MODEL=qwen-plus
ALIBABA_VISION_MODEL=qwen-vl-plus
ALIBABA_CODER_MODEL=qwen3-coder-plus
ALIBABA_TRANSLATION_MODEL=qwen-mt-plus

# Cerebras API Configuration (Optional)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b

# Groq Configuration (Optional - Ultra-fast inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Amazon Bedrock Configuration (Optional)
BEDROCK_ACCESS_KEY=your_aws_access_key_here
BEDROCK_SECRET_KEY=your_aws_secret_key_here
BEDROCK_REGION=us-west-2
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_AUTH_METHOD=auto

# ===================
# Embeddings Configuration
# ===================
# Embedding provider: local, huggingface
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===================
# Vector Database (ChromaDB)
# ===================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=durgasai_pages

# ===================
# Database
# ===================
DATABASE_URL=sqlite+aiosqlite:///./data/durgasai.db

# ===================
# Redis (Optional - for caching and scaling)
# ===================
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ===================
# Security
# ===================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Key for extension authentication
API_KEY=your-api-key-for-extension

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ===================
# CORS
# ===================
# Comma-separated list of allowed origins
CORS_ORIGINS=chrome-extension://,http://localhost:3000,http://localhost:8080

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json
