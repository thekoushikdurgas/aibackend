# DurgasAI Backend Environment Variables
# Copy this file to .env and fill in your actual API keys

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here

# AI21
AI21_API_KEY=your_ai21_key_here

# Cerebras
CEREBRAS_API_KEY=your_cerebras_key_here

# Groq
GROQ_API_KEY=your_groq_key_here

# NVIDIA
NVIDIA_API_KEY=your_nvidia_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here

# Security
JWT_SECRET_KEY=generate_a_random_secret_key_here
API_KEY=generate_a_random_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/durgasai.db
CHROMA_PERSIST_DIR=./data/chroma

# Redis (optional)
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# Ollama (optional, for local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# CORS
CORS_ORIGINS=chrome-extension://,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Council AI
COUNCIL_MIN_MODELS=3
COUNCIL_MAX_MODELS=5
COUNCIL_TIMEOUT_SECONDS=120

# Self-hosted Supabase (Docker): keep canonical secrets in docker/supabase/supabase.env (see supabase.env.example).
# scripts/docker-up.bat passes --env-file .env --env-file docker/supabase/supabase.env so Compose expands ${POSTGRES_PASSWORD}, ${JWT_SECRET}, ${ANON_KEY}, etc.
# Optional mirrors for local non-Docker tools only:
SUPABASE_URL=http://localhost:8080
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
POSTGRES_PASSWORD=
ANON_KEY=
SERVICE_ROLE_KEY=
JWT_SECRET=
SUPABASE_STUDIO_URL=http://localhost:3001
SUPABASE_ENABLE_REALTIME=true
# Auth and Realtime require a resolvable SUPABASE_URL. Wrong or offline hosts cause
# getaddrinfo / "Cannot reach Supabase" until you fix the URL or start local Supabase.
