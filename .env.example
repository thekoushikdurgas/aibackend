# =============================================================================
# DurgasAI Backend — environment configuration
# Copy to `.env` and fill in values. Variable names match app/config.py Settings
# (UPPER_SNAKE_CASE, case-insensitive). See also config/README.md.
# Never commit `.env` (it holds secrets); `.env` is in `.gitignore`. Commit only this template.
#
# Monorepo: `../config.json` (repo root) is not read by FastAPI. If you still keep provider keys
# there for legacy tools, keep that file out of git (see root `.gitignore`) and duplicate needed
# values here as `HUGGINGFACE_API_KEY`, `GEMINI_API_KEY`, etc., so the API and CI stay consistent.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# --- Security (change in production) ---
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY=generate_a_random_api_key_here

# --- CORS (comma-separated origins; required for credentialed browser clients) ---
CORS_ORIGINS=chrome-extension://,http://localhost:3000,http://127.0.0.1:3000,http://54.146.221.133:8000
# EC2 API example (add your real frontend origins):
# CORS_ORIGINS=chrome-extension://,http://localhost:3000,http://54.146.221.133:8000

# --- Session cookies (durgasos + GraphQL with credentials) ---
# For app.example.com + api.example.com use SESSION_COOKIE_DOMAIN=.example.com and HTTPS.
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- Database & cache ---
DATABASE_URL=sqlite+aiosqlite:///./data/durgasai.db
POSTGRESQL_URL=
DATABASE_PREFER_POSTGRESQL_IN_PRODUCTION=true
POSTGRESQL_POOL_SIZE=20
POSTGRESQL_MAX_OVERFLOW=10
POSTGRESQL_POOL_RECYCLE=3600

REDIS_URL=redis://localhost:6379
USE_REDIS=false

# --- Chroma / RAG ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=durgasai_pages

# --- Runtime AI provider overrides (Durgasos Settings → AI providers; JSON under data/, gitignored) ---
AI_PROVIDER_OVERRIDES_PATH=./data/ai_provider_overrides.json

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Default LLM ---
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_MODEL=steamdj/llama3.1-cpu-only

# --- Ollama ---
# Local uvicorn: localhost. Docker Compose overrides backend to http://ollama:11434/api.
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_CLOUD_URL=https://ollama.com/api
OLLAMA_MODE=localhost
OLLAMA_MODEL=steamdj/llama3.1-cpu-only
# Non-streaming /api/chat read timeout (seconds); large resume/job prompts need more than 120s on slow hosts
OLLAMA_COMPLETION_TIMEOUT_SECONDS=600

# --- Embeddings (RAG; use Ollama embeddinggemma when Ollama serves /api/embed) ---
# If you switch embedding model/dimension, use a new CHROMA_COLLECTION_NAME or reset the DB.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma

# --- Provider API keys (set only what you use) ---
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=
AI21_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=
ANYSCALE_API_KEY=
FAL_API_KEY=
HYPERBOLIC_API_KEY=
REKA_API_KEY=
COHERE_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Additional LLM providers (see config/provider_manifest.json) ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
SAMBANOVA_API_KEY=
GITHUB_AI_API_KEY=
DOCKER_MODEL_RUNNER_BASE_URL=http://localhost:12434/v1
NOVITA_API_KEY=
NEBIUS_API_KEY=
KLUSTER_API_KEY=
LAMINI_API_KEY=
LEPTON_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
DASHSCOPE_API_KEY=
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
STABILITY_API_KEY=
REPLICATE_API_KEY=
EDEN_API_KEY=

# --- Council ---
COUNCIL_MIN_MODELS=3
COUNCIL_MAX_MODELS=5
COUNCIL_TIMEOUT_SECONDS=120

# --- Local storage & realtime (replaces Supabase) ---
STORAGE_ROOT=./data/storage
STORAGE_URL_PREFIX=/files
STORAGE_SIGNED_URL_SECRET=
STORAGE_SIGNED_URL_TTL=3600
STORAGE_BUCKET_UPLOADS=user-uploads
STORAGE_BUCKET_AVATARS=user-avatars
STORAGE_BUCKET_DOCUMENTS=rag-documents
SOCKETIO_CORS_ORIGINS=*
SOCKETIO_MOUNT_PATH=/realtime

# --- Docker Compose (Postgres service) ---
POSTGRES_PASSWORD=postgres
POSTGRES_EXTERNAL_PORT=5432
# Host port published for Redis (container still uses 6379). If bind fails with
# "port is already allocated", set e.g. REDIS_EXTERNAL_PORT=6380. Services inside
# Compose keep using redis://redis:6379; only host-side tools / a local API need the mapped port.
REDIS_EXTERNAL_PORT=6379
# Legacy (unused by production docker/docker-compose.yml): internal services are not
# published to the host. Do NOT set *_PUBLISH_HOST to your EC2 public IP (e.g. 54.x.x.x).
# HOST below is for uvicorn bind inside the container (0.0.0.0), not Docker port mapping.

# --- EC2 production quick reference (see deploy/EC2.md) ---
# ENVIRONMENT=production
# DEBUG=false
# USE_REDIS=true
# STORAGE_SIGNED_URL_SECRET=<random>

# --- AWS (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
