# DurgasAI Backend — private environment (do not commit; see .gitignore).
# Template and full key list: .env.example  |  Settings: app/config.py
# If this file was ever pushed to git, rotate POSTGRES_PASSWORD, JWT_SECRET_KEY, and API_KEY.

# ===================
# Server Configuration
# ===================
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# ===================
# AI Provider Settings
# ===================
# Default LLM provider: ollama, huggingface, gemini
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_MODEL=steamdj/llama3.1-cpu-only

# Ollama Configuration
OLLAMA_BASE_URL=http://54.167.242.75:11434
OLLAMA_MODEL=steamdj/llama3.1-cpu-only

# HuggingFace Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Google Gemini Configuration (Optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ===================
# Embeddings Configuration
# ===================
# Embedding provider: local, huggingface, ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma

# ===================
# Vector Database (ChromaDB)
# ===================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=durgasai_pages

# ===================
# Database
# ===================
# Host / IDE / pytest against Docker Postgres (port published as POSTGRES_EXTERNAL_PORT): password is URL-encoded.
DATABASE_URL=postgresql+asyncpg://postgres:5eIyN8PdFINnoazmzWPI0g2lawFLDD%2Fp2AAUI5wfPDs%3D@54.167.242.75:5432/postgres
POSTGRESQL_URL=postgresql+asyncpg://postgres:5eIyN8PdFINnoazmzWPI0g2lawFLDD%2Fp2AAUI5wfPDs%3D@54.167.242.75:5432/postgres
# SQLite-only local mode (no Postgres): uncomment below and comment the two lines above.
# DATABASE_URL=sqlite+aiosqlite:///./data/durgasai.db

# ===================
# Redis (Optional - for caching and scaling)
# ===================
REDIS_URL=redis://54.167.242.75:6379
USE_REDIS=false

# ===================
# Security
# ===================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key for extension authentication
API_KEY=your-api-key-for-extension

# --- Session cookies (durgasos + GraphQL with credentials) ---
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ===================
# CORS
# ===================
# Comma-separated list of allowed origins (include every browser/extension origin that calls this API)
CORS_ORIGINS=chrome-extension://,http://54.167.242.75:3000

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Council AI
COUNCIL_MIN_MODELS=3
COUNCIL_MAX_MODELS=5
COUNCIL_TIMEOUT_SECONDS=120

# --- Docker Compose: Postgres db service (must match password embedded in DATABASE_URL above) ---
POSTGRES_PASSWORD=5eIyN8PdFINnoazmzWPI0g2lawFLDD/p2AAUI5wfPDs=
POSTGRES_EXTERNAL_PORT=5432

# --- Local file storage & Socket.IO (defaults match app/config.py) ---
STORAGE_ROOT=./data/storage
STORAGE_URL_PREFIX=/files
STORAGE_SIGNED_URL_SECRET=
STORAGE_SIGNED_URL_TTL=3600
STORAGE_BUCKET_UPLOADS=user-uploads
STORAGE_BUCKET_AVATARS=user-avatars
STORAGE_BUCKET_DOCUMENTS=rag-documents
SOCKETIO_CORS_ORIGINS=*
SOCKETIO_MOUNT_PATH=/realtime
