# DurgasAI Backend Configuration
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# ===================
# AI Provider Settings
# ===================
# Default LLM provider: ollama, huggingface, gemini
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_MODEL=llama3

# Ollama Configuration
OLLAMA_BASE_URL=http://54.167.242.75:11434
OLLAMA_MODEL=llama3

# HuggingFace Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Google Gemini Configuration (Optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ===================
# Embeddings Configuration
# ===================
# Embedding provider: local, huggingface
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===================
# Vector Database (ChromaDB)
# ===================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=durgasai_pages

# ===================
# Database
# ===================
# Host / IDE / pytest against Docker Postgres (port published as POSTGRES_EXTERNAL_PORT): password is URL-encoded.
DATABASE_URL=postgresql+asyncpg://postgres:5eIyN8PdFINnoazmzWPI0g2lawFLDD%2Fp2AAUI5wfPDs%3D@127.0.0.1:5432/postgres
POSTGRESQL_URL=postgresql+asyncpg://postgres:5eIyN8PdFINnoazmzWPI0g2lawFLDD%2Fp2AAUI5wfPDs%3D@127.0.0.1:5432/postgres
# SQLite-only local mode (no Postgres): uncomment below and comment the two lines above.
# DATABASE_URL=sqlite+aiosqlite:///./data/durgasai.db

# ===================
# Redis (Optional - for caching and scaling)
# ===================
REDIS_URL=redis://54.167.242.75:6379
USE_REDIS=false

# ===================
# Security
# ===================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Key for extension authentication
API_KEY=your-api-key-for-extension

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ===================
# CORS
# ===================
# Comma-separated list of allowed origins
CORS_ORIGINS=chrome-extension://,http://54.167.242.75:3000,http://54.167.242.75:8080

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Council AI
COUNCIL_MIN_MODELS=3
COUNCIL_MAX_MODELS=5
COUNCIL_TIMEOUT_SECONDS=120

# Self-hosted Supabase (Docker): canonical Supabase stack vars live in docker/supabase/supabase.env (must stay in sync).
# Compose merges .env + supabase.env; backend container overrides SUPABASE_URL to http://kong:8000 internally.
# Below mirrors Kong/API gateway URL on the host (same as SUPABASE_PUBLIC_URL in supabase.env) plus JWT keys for app/realtime clients.
SUPABASE_URL=http://54.167.242.75:8080
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwiaWF0IjoxNzc4MzkxMjQ3LCJleHAiOjIwOTM3NTEyNDcsInJvbGUiOiJhbm9uIn0.KTmUPuLQerFACk3nBTb0Vb3xd1J9F6Y_9U9pKn1oO-0
